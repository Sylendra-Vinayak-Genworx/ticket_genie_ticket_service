# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED
DATABASE_URL=postgresql+asyncpg://user:password@localhost/mydb

SECRET_KEY=change-me-at-least-32-chars-long-here
ALGORITHM=HS256

AUTH_SERVICE_URL=http://localhost:8001

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
DEFAULT_RESPONSE_TIME_MINUTES=480
DEFAULT_RESOLUTION_TIME_MINUTES=2880
DEFAULT_ESCALATION_AFTER_MINUTES=120
LEAD_TIMEOUT_MINUTES=15
AUTO_CLOSE_AFTER_HOURS=4320

# ── External APIs ─────────────────────────────────────────────────────────────
# REQUIRED if using LLM email parsing
GROQ_API_KEY=your_groq_api_key

# ── Similarity routing ────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.60
MAX_OPEN_TICKETS=10
# REQUIRED if using HuggingFace embeddings
HF_TOKEN=your_hf_token
FRONTEND_URL=http://localhost:5173

# ── IMAP (inbound email) ──────────────────────────────────────────────────────
# Leave IMAP_HOST blank to disable email polling entirely.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# ── SMTP (outbound email) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME="Support Team"

# ── Google Cloud Storage ──────────────────────────────────────────────────────
GCS_ENABLED=True
GCS_PROJECT_ID=gwx-internship-01
GCS_BUCKET_NAME=gwx-stg-intern-01
GCS_BUCKET_PREFIX=ticketing-genie
GCS_TARGET_SERVICE_ACCOUNT=gwx-cloudrun-sa-01@gwx-internship-01.iam.gserviceaccount.com

# ── Agents & Assignment ───────────────────────────────────────────────────────
ASSIGNING_LOCK_TIMEOUT_MINUTES=10
MAX_AGENT_WORKLOAD=10
EXPERIENCE_CAP=50
